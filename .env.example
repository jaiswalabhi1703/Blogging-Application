# ============================================================
#  Copy to .env and fill in. NEVER commit the real .env file.
# ============================================================

# ---- PostgreSQL (used by docker-compose) ----
POSTGRES_DB=blog_app
POSTGRES_USER=blog
POSTGRES_PASSWORD=change-me-strong-password

# ---- Spring datasource (prod profile; set automatically by docker-compose) ----
# DATABASE_URL=jdbc:postgresql://localhost:5432/blog_app
# DATABASE_USERNAME=blog
# DATABASE_PASSWORD=change-me-strong-password

# ---- Security ----
# Strong, Base64-encoded HMAC secret (>= 256 bits). Generate with:
#   openssl rand -base64 48
JWT_SECRET=5367566B59703373367639792F423F4528482B4D6251655468576D5A71347437
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Comma-separated allowed browser origins (your frontend / Cloudflare domain)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.pages.dev

# ---- AI assistant (optional) ----
# Leave blank to run without AI features.
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENABLED=true

# ---- Kafka (event-driven notifications) & Redis (cache-aside) ----
# docker-compose sets these to true automatically. For a bare `mvn spring-boot:run`
# leave them false (notifications run synchronously, cache is in-memory).
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
